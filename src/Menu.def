DEFINITION MODULE Menu;

(* Menu system matching the original Faery Tale Adventure.
   11 menu modes with 2-column option layout. *)

CONST
  MItems = 0;  MMagic = 1;  MTalk  = 2;  MBuy   = 3;  MGame  = 4;
  MSave  = 5;  MKeys  = 6;  MGive  = 7;  MUse   = 8;  MFile  = 9;
  MSell  = 10;

  MaxOpts = 12;

  (* Menu panel layout in 640x57 HUD space *)
  PanelX = 430;
  PanelY = 2;
  BtnW   = 52;
  BtnH   = 9;

TYPE
  MenuDef = RECORD
    labels: ARRAY [0..59] OF CHAR;  (* up to 12 options, 5 chars each *)
    num:    INTEGER;                 (* total slots including tabs *)
    color:  INTEGER;                 (* palette color index *)
    enabled: ARRAY [0..11] OF INTEGER
      (* bit0=selected, bit1=displayed, bits2-7=type:
         4=toggle, 8=immediate, 12=radio, 0=fixed *)
  END;

VAR
  cmode: INTEGER;                     (* current menu mode *)
  menus: ARRAY [0..10] OF MenuDef;
  realOptions: ARRAY [0..11] OF INTEGER;  (* visible option indices *)
  optionCount: INTEGER;               (* number of visible options *)

PROCEDURE InitMenus;
PROCEDURE SetOptions;
PROCEDURE GoMenu(mode: INTEGER);
PROCEDURE HandleMenuKey(ch: CHAR);

END Menu.
