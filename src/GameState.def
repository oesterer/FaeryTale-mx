DEFINITION MODULE GameState;

(* Pure Modula-2 game state management *)

CONST
  FrameTime = 33;  (* ~30fps matching Amiga actual game loop rate *)
  MsgLen    = 255;
  ViewNormal    = 0;
  ViewInventory = 4;
  ViewBird      = 5;
  NumStoneCircles = 11;

VAR
  running: BOOLEAN;
  cycle: INTEGER;
  dayNight: INTEGER;
  msgText: ARRAY [0..255] OF CHAR;
  msgTimer: INTEGER;

VAR
  mapToggled: BOOLEAN;
  regionFade: INTEGER;  (* >0 = fading during region switch *)
  viewStatus: INTEGER;  (* ViewNormal, ViewInventory, or ViewBird *)
  secretTimer: INTEGER;  (* >0 reveals hidden objects *)
  fairyActive: BOOLEAN;
  fairyX: INTEGER;  (* fairy screen X in world coords *)
  colorPlayTimer: INTEGER;  (* >0 = color cycling effect active *)
  witchFlag: BOOLEAN;       (* TRUE when witch is active on screen *)
  witchIndex: INTEGER;      (* beam rotation angle 0-255 wraps *)
  witchDir: INTEGER;        (* beam rotation direction +1 or -1 *)
  witchS1, witchS2: INTEGER; (* cross-product signs for beam hit detection *)

PROCEDURE InitGame;
PROCEDURE UpdateGame;
PROCEDURE ShowMessage(msg: ARRAY OF CHAR);
PROCEDURE GetStoneCircle(i: INTEGER; VAR x, y: INTEGER);

END GameState.
