DEFINITION MODULE Brothers;

(* Pure Modula-2 three-brothers system.
   In the original, when one brother dies the next takes over.
   Each has different starting stats. *)

CONST
  Julian = 0;
  Philip = 1;
  Kevin  = 2;
  NumBrothers = 3;

  (* stuff[] indices for progression items *)
  StLasso    = 5;   (* Golden Lasso *)
  StShell    = 6;   (* Sea Shell *)
  StSunStone = 7;   (* Sun Stone *)
  StTalisman = 22;  (* Talisman — win condition *)
  StStatue   = 25;  (* Gold Statue count — need 5 *)
  StWrit     = 28;  (* Writ from king *)
  StBone     = 29;  (* King's Bone *)
  StShard    = 30;  (* Shard — traversal gate *)
  StMandrake = 31;
  StWolfsbane = 32;
  StMugwort = 33;
  StYarrow = 34;
  StNightshade = 35;
  StBloodroot = 36;
  StWardScroll = 37;
  StFreezeScroll = 38;
  StFireScroll = 39;
  StFearScroll = 40;
  StLightScroll = 41;
  StSanctuaryScroll = 42;
  StHarvestScroll = 43;
  StHealScroll = 44;
  LastStuff = 44;

TYPE
  BrotherData = RECORD
    name:     ARRAY [0..15] OF CHAR;
    vitality: INTEGER;
    weapon:   INTEGER;
    brave:    INTEGER;
    luck:     INTEGER;
    kind:     INTEGER;
    wealth:   INTEGER;
    weaponInv: ARRAY [0..5] OF INTEGER;  (* count per weapon type *)
    stuff:    ARRAY [0..LastStuff] OF INTEGER;
    startX:   INTEGER;
    startY:   INTEGER;
    alive:    BOOLEAN
  END;

VAR
  brothers: ARRAY [0..2] OF BrotherData;
  activeBrother: INTEGER;

PROCEDURE HasStuff(idx: INTEGER): BOOLEAN;
PROCEDURE HasWeapon(idx: INTEGER): BOOLEAN;
PROCEDURE GiveStuff(idx: INTEGER);
PROCEDURE AddStuffN(idx, n: INTEGER);
PROCEDURE SetStuff(idx, val: INTEGER);
PROCEDURE AddWealth(amount: INTEGER);
PROCEDURE IncBrave;
PROCEDURE DecLuck(amount: INTEGER);
PROCEDURE DecKind(amount: INTEGER);
PROCEDURE IncKind;
PROCEDURE InitBrothers;
PROCEDURE SwitchToNext(): BOOLEAN;
PROCEDURE ActiveName(VAR name: ARRAY OF CHAR);
PROCEDURE SaveBrotherState;
PROCEDURE RestoreBrotherState;

END Brothers.
