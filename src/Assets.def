DEFINITION MODULE Assets;

(* Asset loading for original game data.
   Binary parsing is pure M2. BMP textures loaded via Platform. *)

FROM SYSTEM IMPORT ADDRESS;

CONST
  NumRegions  = 10;
  SectorSize  = 32768;
  MapSize     = 4096;
  TerrainSize = 512;
  TileW       = 16;
  TileH       = 32;
  MaxPathLen  = 127;

TYPE
  RegionDef = RECORD
    image:   ARRAY [0..3] OF INTEGER;
    terra1:  INTEGER;
    terra2:  INTEGER;
    sector:  INTEGER;
    region:  INTEGER;
    name:    ARRAY [0..31] OF CHAR
  END;

VAR
  regions: ARRAY [0..9] OF RegionDef;
  sectorMem: ARRAY [0..32767] OF CHAR;
  mapMem:    ARRAY [0..4095] OF CHAR;
  terraMem:  ARRAY [0..1023] OF CHAR;
  currentRegion: INTEGER;
  tileTex: ARRAY [0..3] OF ADDRESS;
  tileOverlay: ARRAY [0..3] OF ADDRESS;  (* same tiles with black=transparent *)
  tilePB: ARRAY [0..3] OF ADDRESS;      (* tile PixBufs for blitter *)
  shadowPB: ADDRESS;                     (* shadow_mem mask PixBuf *)
  hudTex:  ADDRESS;
  brotherTex: ARRAY [0..2] OF ADDRESS;  (* Julian=0, Phillip=1, Kevin=2 *)
  enemyTex: ARRAY [0..4] OF ADDRESS;   (* 0=Ogre, 1=Ghost, 2=DKnight, 3=Necro, 4=Snake *)
  npcTex: ARRAY [0..5] OF ADDRESS;     (* 0=Wizard, 1=Royal, 2=Bartender, 3=Witch, 4=Ranger, 5=Scroll Priest *)
  dragonTex: ADDRESS;                  (* shape_10 Dragon 48x40 x5 *)
  xReg, yReg: INTEGER;

(* Build full path: basePath + filename → result *)
PROCEDURE AssetPath(name: ARRAY OF CHAR; VAR result: ARRAY OF CHAR);

PROCEDURE LoadImgCached(num: INTEGER): ADDRESS;
PROCEDURE InitAssets;
PROCEDURE PreloadAll(): BOOLEAN;
PROCEDURE LoadHUD(targetW, targetH: INTEGER): BOOLEAN;
PROCEDURE SwitchRegion(regionIdx: INTEGER);
PROCEDURE GetSectorByte(x, y: INTEGER): INTEGER;
PROCEDURE SetSectorByte(x, y, val: INTEGER);
PROCEDURE GetMapSector(x, y: INTEGER): INTEGER;
PROCEDURE SetMapSector(x, y, val: INTEGER);
PROCEDURE GetSectorByteForRegion(x, y, regIdx: INTEGER): INTEGER;
PROCEDURE GetTerrainAt(x, y: INTEGER): INTEGER;
PROCEDURE GetMaskType(secByte: INTEGER): INTEGER;
PROCEDURE GetTilesBits(secByte: INTEGER): INTEGER;
PROCEDURE GetMapTag(secByte: INTEGER): INTEGER;
PROCEDURE IsBlocked(x, y: INTEGER): BOOLEAN;
PROCEDURE TerrainSpeedAt(x, y: INTEGER): INTEGER;
PROCEDURE DetectRegion(px, py: INTEGER): INTEGER;
PROCEDURE CheckRegionSwitch(px, py: INTEGER);

END Assets.
