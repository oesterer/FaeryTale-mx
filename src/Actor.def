DEFINITION MODULE Actor;

(* Pure Modula-2 actor/entity types matching original game structures *)

CONST
  MaxActors = 48;

  (* Motion states *)
  StWalking  = 12;
  StStill    = 13;
  StFighting = 0;
  StDying    = 14;
  StDead     = 15;
  StSink     = 16;
  StFrozen   = 20;
  StFlying   = 21;
  StFall     = 22;
  StSleep    = 23;
  StShoot1   = 24;
  StShoot3   = 25;

  (* Actor types — matches original sequences enum *)
  TypePlayer  = 0;
  TypeObject  = 1;
  TypeEnemy   = 2;
  TypeRaft    = 3;
  TypeSetfig  = 4;
  TypeCarrier = 5;
  TypeDragon  = 6;

  (* Goal modes — matches original #defines *)
  GoalUser     = 0;
  GoalAttack1  = 1;
  GoalAttack2  = 2;
  GoalArcher1  = 3;
  GoalArcher2  = 4;
  GoalFlee     = 5;
  GoalStand    = 6;
  GoalDeath    = 7;
  GoalWait     = 8;
  GoalFollow   = 9;
  GoalConfused = 10;

  (* Tactic modes — matches original do_tactic *)
  TacPursue    = 1;
  TacFollow    = 2;
  TacBumble    = 3;
  TacRandom    = 4;
  TacBackup    = 5;
  TacEvade     = 6;
  TacShoot     = 8;
  TacFrust     = 9;
  TacShootFrust = 10;
  TacEggSeek   = 11;

TYPE
  Actor = RECORD
    absX, absY: INTEGER;
    relX, relY: INTEGER;
    actorType:  INTEGER;
    race:       INTEGER;
    index:      INTEGER;
    visible:    BOOLEAN;
    weapon:     INTEGER;
    environ:    INTEGER;
    goal:       INTEGER;
    tactic:     INTEGER;
    state:      INTEGER;
    facing:     INTEGER;
    vitality:   INTEGER;
    velX, velY: INTEGER
  END;

VAR
  actors: ARRAY [0..47] OF Actor;
  actorCount: INTEGER;

PROCEDURE InitActor(VAR a: Actor);
PROCEDURE InitAll;

END Actor.
